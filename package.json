{
  "name": "uspto-bulk-search",
  "version": "1.0.0",
  "description": "USPTO Trademark Clearance Search Tool for IP attorneys and paralegals",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "wait-on http://localhost:5173 && electron .",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder",
    "pack": "npm run build:renderer && electron-builder --dir",
    "test": "vitest run"
  },
  "dependencies": {
    "bottleneck": "^2.19.5",
    "electron-store": "^8.2.0",
    "flexsearch": "^0.7.43",
    "papaparse": "^5.4.1",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "wait-on": "^7.2.0"
  }
}
