{
  "name": "@uspto-search/desktop",
  "version": "1.0.7",
  "description": "USPTO Bulk Search - Electron Desktop App",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "wait-on http://localhost:5173 && electron .",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder",
    "pack": "npm run build:renderer && electron-builder --dir"
  },
  "dependencies": {
    "@uspto-search/core": "*",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "vite": "^8.0.0",
    "wait-on": "^7.2.0"
  }
}
